{
  "type": "project",
  "license": "proprietary",
  "minimum-stability": "stable",
  "prefer-stable": true,
  "repositories": [
    {
      "type": "path",
      "url": "../../packages/core",
      "options": {
        "symlink": true
      }
    }
  ],
  "require": {
    "php": ">=8.3",
    "doctrine/dbal": "^4.0",
    "doctrine/doctrine-bundle": "^2.18",
    "doctrine/doctrine-migrations-bundle": "^3.4",
    "lexik/jwt-authentication-bundle": "^3.1",
    "nelmio/api-doc-bundle": "^5.0",
    "nelmio/cors-bundle": "^2.5",
    "socialbulletin/core": "dev-main",
    "symfony/console": "^7.0",
    "symfony/dotenv": "^7.0",
    "symfony/framework-bundle": "^7.0",
    "symfony/monolog-bundle": "^3.10",
    "symfony/runtime": "^7.0",
    "symfony/security-bundle": "^7.0",
    "symfony/translation": "^7.0",
    "symfony/uid": "^7.0",
    "symfony/yaml": "^7.0",
    "webmozart/assert": "^1.11"
  },
  "require-dev": {
    "behat/behat": "^3.15",
    "deptrac/deptrac": "^3.0",
    "friends-of-behat/symfony-extension": "^2.5",
    "mtdowling/jmespath.php": "^2.8",
    "phpstan/phpstan": "^2.0",
    "phpspec/phpspec": "^7.5",
    "symfony/browser-kit": "^7.0",
    "symfony/css-selector": "^7.0",
    "symplify/easy-coding-standard": "^12.0"
  },
  "autoload": {
    "psr-4": {
      "SocialBulletin\\Api\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "SocialBulletin\\Api\\Tests\\": "tests/",
      "SocialBulletin\\Api\\Features\\Bootstrap\\": "features/bootstrap/"
    }
  },
  "extra": {
    "symfony": {
      "allow-contrib": false,
      "require": "7.0.*"
    }
  },
  "config": {
    "allow-plugins": {
      "symfony/runtime": true
    },
    "sort-packages": true
  }
}
