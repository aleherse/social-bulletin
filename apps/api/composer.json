{
    "type": "project",
    "license": "proprietary",
    "minimum-stability": "dev",
    "prefer-stable": true,
    "require": {
        "php": ">=8.2",
        "ext-ctype": "*",
        "ext-iconv": "*",
        "doctrine/dbal": "^4",
        "doctrine/doctrine-bundle": "^2",
        "doctrine/doctrine-migrations-bundle": "^3",
        "doctrine/migrations": "^3",
        "lexik/jwt-authentication-bundle": "^3",
        "nelmio/api-doc-bundle": "^5",
        "nelmio/cors-bundle": "^2",
        "socialbulletin/core": "*",
        "symfony/console": "7.4.*",
        "symfony/dotenv": "7.4.*",
        "symfony/flex": "^2",
        "symfony/framework-bundle": "7.4.*",
        "symfony/monolog-bundle": "*",
        "symfony/runtime": "7.4.*",
        "symfony/security-bundle": "7.4.*",
        "symfony/translation": "7.4.*",
        "symfony/translation-contracts": "*",
        "symfony/uid": "7.4.*",
        "symfony/yaml": "7.4.*",
        "webmozart/assert": "^1",
        "zircote/swagger-php": "^6"
    },
    "repositories": [
        {
            "type": "path",
            "url": "../../packages/core",
            "options": {
                "symlink": true
            }
        }
    ],
    "require-dev": {
        "behat/behat": "^3",
        "deptrac/deptrac": "^3",
        "friends-of-behat/symfony-extension": "^2",
        "mtdowling/jmespath.php": "^2",
        "phpstan/phpstan": "^2",
        "symfony/browser-kit": "7.4.*",
        "symfony/process": "7.4.*",
        "symplify/easy-coding-standard": "^12"
    },
    "config": {
        "allow-plugins": {
            "php-http/discovery": true,
            "symfony/flex": true,
            "symfony/runtime": true
        },
        "bump-after-update": true,
        "sort-packages": true
    },
    "autoload": {
        "psr-4": {
            "SocialBulletin\\Api\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SocialBulletin\\Api\\Tests\\": "tests/"
        }
    },
    "replace": {
        "symfony/polyfill-ctype": "*",
        "symfony/polyfill-iconv": "*",
        "symfony/polyfill-php72": "*",
        "symfony/polyfill-php73": "*",
        "symfony/polyfill-php74": "*",
        "symfony/polyfill-php80": "*",
        "symfony/polyfill-php81": "*",
        "symfony/polyfill-php82": "*"
    },
    "scripts": {
        "auto-scripts": {
            "cache:clear": "symfony-cmd",
            "assets:install %PUBLIC_DIR%": "symfony-cmd"
        },
        "post-install-cmd": [
            "@auto-scripts"
        ],
        "post-update-cmd": [
            "@auto-scripts"
        ],
        "test": "behat"
    },
    "conflict": {
        "symfony/symfony": "*"
    },
    "extra": {
        "symfony": {
            "allow-contrib": false,
            "require": "7.4.*"
        }
    }
}
