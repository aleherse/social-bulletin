default:
  suites:
    api:
      paths:
        - features
      contexts:
        - SocialBulletin\Api\Features\Bootstrap\ApiContext
  extensions:
    FriendsOfBehat\SymfonyExtension:
      kernel:
        class: SocialBulletin\Api\Kernel
        environment: test
        debug: true
  gherkin:
    filters:
      tags: ~@fixtures
