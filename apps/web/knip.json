{
  "entry": ["src/app/main.tsx", "src/shared/ui/**/*.tsx", "vite.config.ts", "eslint.config.js"],
  "project": ["src/**/*.{ts,tsx}", "*.config.{js,ts}"],
  "ignore": [
    "dist/**",
    "build/**",
    "coverage/**",
    "node_modules/**",
    ".vite/**",
    "test-results/**",
    "playwright-report/**"
  ],
  "ignoreDependencies": [
    "@fontsource-variable/geist",
    "lefthook",
    "shadcn",
    "tailwindcss",
    "tw-animate-css"
  ],
  "ignoreExportsUsedInFile": true
}
