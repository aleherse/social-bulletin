# ADR-0012: aligned with Easy Coding Standard (PSR-12) and Prettier settings.
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

# Prettier-owned file types (tabWidth: 2, printWidth: 100)
[*.{ts,tsx,js,jsx,json,jsonc,css,html,yml,yaml}]
indent_size = 2
max_line_length = 100

[*.md]
trim_trailing_whitespace = false

[Makefile]
indent_style = tab
