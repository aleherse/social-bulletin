# SocialBulletin local environment
# Project constants from specs/decisions/ADR-0000-project-documentation-constants.md.
PROJECT_NAME=SocialBulletin
PROJECT_SLUG=socialbulletin
PROJECT_NAMESPACE=SocialBulletin
DATABASE_SCHEMA=bulletin
DEV_API_URL=api.dev.social.aleherse.com
DEV_FRONT_URL=app.dev.social.aleherse.com
LIVE_API_URL=api.social.aleherse.com
LIVE_FRONT_URL=app.social.aleherse.com

APP_ENV=dev
APP_SECRET=change-me-in-local-env
POSTGRES_DB=socialbulletin
